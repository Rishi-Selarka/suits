# Copy this file to `frontend/.env` and fill in the values from your
# Supabase project (Dashboard → Settings → API).
#
# If you leave these blank, the frontend will boot in dev mode and skip
# the auth gate — matching the backend's dev fallback. Useful for local
# iteration without Supabase.

VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Backend base URL. Leave blank for local dev — Vite proxies /api to
# http://localhost:8000. In production (Vercel), set this to your Render
# service URL, e.g.
#   VITE_API_BASE=https://suits-api.onrender.com
VITE_API_BASE=
