# === Required API Keys ===
OPENROUTER_API_KEY=sk-or-...

# === Server Config ===
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=20
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

